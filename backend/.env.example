PORT=5001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-in-production
CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174

# MongoDB Atlas (recommended for production)
# Get from Atlas: Cluster → Connect → Drivers → Node.js
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/dreammantra_crm?retryWrites=true&w=majority
MONGODB_URI=

# Default admin (created on first run if no admin exists)
ADMIN_EMAIL=admin@dreammantra.in
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Dream Mantra Admin
